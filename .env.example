# ============================================================
#  VARIÁVEIS DE AMBIENTE — "A Cúpula"
# ------------------------------------------------------------
#  Copie este arquivo para ".env" e preencha os valores.
#  NUNCA envie o arquivo ".env" para o GitHub (ele já está no .gitignore).
# ============================================================

# --- App Google (login + agenda) ---------------------------
# Crie em: https://console.cloud.google.com  →  APIs e Serviços  →  Credenciais
# Tipo: "ID do cliente OAuth" → "Aplicativo da Web".
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# --- Segurança do login (Auth.js) --------------------------
# Gere um valor aleatório. No terminal:  openssl rand -base64 32
AUTH_SECRET=

# Endereço público do site. Em produção, a URL real (ex.: https://cupula.suaempresa.com).
# Em desenvolvimento, deixe http://localhost:3000
AUTH_URL=http://localhost:3000

# --- Agenda da concierge (DISPONIBILIDADE) -----------------
# Usada só para LER os horários ocupados (não trava a agenda central).
# Rode "npm run setup:calendar" logado com a conta da CONCIERGE.
CONCIERGE_REFRESH_TOKEN=

# E-mail (ID) da agenda da concierge (de onde lemos os horários ocupados).
# Normalmente o e-mail da concierge. Use "primary" para a agenda principal dela.
CONCIERGE_CALENDAR_ID=concierge@suaempresa.com

# E-mail da concierge (para convidá-la como participante no evento).
# Se vazio, usa o CONCIERGE_CALENDAR_ID acima (quando for um e-mail).
CONCIERGE_EMAIL=

# --- Agenda CENTRAL (cria o evento / grava a reunião) -------
# Conta ORGANIZADORA do evento (ex.: central@cupulared.com.br).
# Rode "npm run setup:calendar" logado com ESSA conta para gerar o token.
# Se ficar em branco, o evento é criado na agenda da concierge (reserva).
CENTRAL_REFRESH_TOKEN=
CENTRAL_CALENDAR_ID=central@cupulared.com.br

# Gravar as reuniões automaticamente (via Google Meet API, conta central).
# Requer a Meet API ativada no Google Cloud e um Workspace que suporte
# gravação. Se falhar, o evento é criado com Meet normal (sem gravar).
GRAVAR_REUNIOES=false

# --- Opcionais ---------------------------------------------
# E-mail da Cúpula: se preenchido, é convidado ao evento para a equipe também ver.
# Deixe em branco para criar o evento apenas na agenda da concierge.
CUPULA_EMAIL=

# Restringir quem pode marcar (e-mails separados por vírgula).
# Deixe em branco para permitir qualquer pessoa logada com Google.
MENTORADOS_AUTORIZADOS=

# E-mails que podem acessar o PAINEL da concierge (/painel), separados por vírgula.
# Normalmente o e-mail da concierge. Sem isso, o painel fica indisponível.
ADMIN_EMAILS=concierge@suaempresa.com
